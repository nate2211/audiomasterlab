{
  "name": "audiowebsite",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@comfyorg/fbx-exporter-three": "^1.0.1",
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.11.5",
    "@huggingface/transformers": "^4.2.0",
    "@mui/icons-material": "5.15.21",
    "@mui/material": "5.15.21",
    "@react-router/node": "^7.18.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "dexie": "^4.4.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-redux": "^9.3.0",
    "react-router": "^7.18.1",
    "react-router-dom": "^7.18.1",
    "react-scripts": "5.0.1",
    "three": "^0.185.1",
    "web-vitals": "^2.1.4",
    "workbox-window": "^7.4.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "react-snap && node scripts/verify-prerender.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "react-snap": "1.23.0"
  },
  "reactSnap": {
    "source": "build",
    "destination": "build",
    "include": [
      "/",
      "/audio",
      "/editor",
      "/recorder",
      "/youtube",
      "/news",
      "/transcribe",
      "/visualizer",
      "/archive",
      "/community",
      "/help",
      "/about",
      "/contact",
      "/privacy",
      "/terms",
      "/copyright"
    ],
    "crawl": false,
    "concurrency": 1,
    "skipThirdPartyRequests": true,
    "cacheAjaxRequests": false,
    "inlineCss": false,
    "minifyHtml": false,
    "fixWebpackChunksIssue": false,
    "preconnectThirdParty": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
